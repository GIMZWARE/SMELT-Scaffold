# SMELT Environment Configuration
# Copy to .env and fill in required values: cp .env.example .env

# === REQUIRED ===
ANTHROPIC_API_KEY=sk-ant-your-key-here    # Required for LLM agent calls

# === INFRASTRUCTURE (defaults work with docker-compose) ===
NATS_URL=nats://localhost:4222
REDIS_URL=redis://localhost:6379
POSTGRES_URL=postgresql+asyncpg://smelt:smelt@localhost:5432/smelt

# === OBSERVABILITY ===
JAEGER_ENDPOINT=http://localhost:4317     # OTLP gRPC endpoint
OTEL_ENABLED=true
LOG_LEVEL=INFO                            # DEBUG, INFO, WARNING, ERROR

# === LLM CONFIGURATION ===
LLM_DEFAULT_MODEL=claude-haiku-4-5-20251001
